<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Chess.UI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:styles="using:Chess.UI.Styles"
    xmlns:ui="using:Chess.UI.UI"
    mc:Ignorable="d">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///UI/ComboBoxTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ui:PieceStylePreviewConverter x:Key="PieceStylePreviewConverter" />
            <ui:BoardStylePreviewConverter x:Key="BoardStylePreviewConverter" />

            <ui:SectionedTemplateSelector
                x:Key="NetworkAdapterSelector"
                DividerTemplate="{StaticResource DividerTemplate}"
                HeaderTemplate="{StaticResource HeaderTemplate}"
                ItemTemplate="{StaticResource NetworkAdapterTemplate}">
                <ui:SectionedTemplateSelector.ItemTemplateSelector>
                    <ui:ComboboxItemTemplateSelector
                        ItemTemplate="{StaticResource NetworkAdapterTemplate}"
                        SelectedItemContentTemplate="{StaticResource SelectedNetworkAdapterTemplate}" />
                </ui:SectionedTemplateSelector.ItemTemplateSelector>
            </ui:SectionedTemplateSelector>

            <!--  Piece Style Item Template  -->
            <DataTemplate x:Key="PieceStyleItemTemplate" x:DataType="styles:PieceStyleInfo">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Image
                        Width="28"
                        Height="28"
                        Source="{Binding Style, Converter={StaticResource PieceStylePreviewConverter}}" />
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayName}" />
                </StackPanel>
            </DataTemplate>

            <!--  Board Style Item Template  -->
            <DataTemplate x:Key="BoardStyleItemTemplate" x:DataType="styles:BoardStyleInfo">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border
                        Width="40"
                        Height="28"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="4">
                        <Image Source="{Binding Style, Converter={StaticResource BoardStylePreviewConverter}}" Stretch="UniformToFill" />
                    </Border>
                    <TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayName}" />
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="860"
            Padding="32"
            HorizontalAlignment="Center"
            RowSpacing="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- Header -->
                <RowDefinition Height="Auto" />
                <!-- Appearance + Preview -->
                <RowDefinition Height="Auto" />
                <!-- Audio -->
                <RowDefinition Height="Auto" />
                <!-- Multiplayer -->
                <RowDefinition Height="48" />
                <!-- Bottom spacing -->
            </Grid.RowDefinitions>


            <!-- ==================== HEADER ==================== -->
            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="12">
                <Button
                    Click="BackButton_Click"
                    Style="{ThemeResource NavigationBackButtonNormalStyle}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="Settings" />
            </StackPanel>


            <!-- ==================== APPEARANCE + LIVE PREVIEW ==================== -->
            <Border
                Grid.Row="1"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24">
                <Grid ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <!-- Controls -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Live preview -->
                    </Grid.ColumnDefinitions>

                    <!-- Appearance Controls -->
                    <StackPanel
                        Grid.Column="0"
                        Spacing="20"
                        VerticalAlignment="Center">

                        <StackPanel Spacing="4">
                            <TextBlock
                                FontSize="20"
                                FontWeight="SemiBold"
                                Text="Appearance" />
                            <TextBlock
                                FontSize="13"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Customize the look of your board and pieces" />
                        </StackPanel>

                        <!-- Board Theme -->
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="BOARD THEME" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemTemplate="{StaticResource BoardStyleItemTemplate}"
                                ItemsSource="{x:Bind _stylesViewModel.BoardThemes}"
                                SelectedItem="{x:Bind _stylesViewModel.SelectedBoardTheme, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Piece Style -->
                        <StackPanel Spacing="6">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="PIECE STYLE" />
                            <ComboBox
                                HorizontalAlignment="Stretch"
                                ItemTemplate="{StaticResource PieceStyleItemTemplate}"
                                ItemsSource="{x:Bind _stylesViewModel.PieceThemes}"
                                SelectedItem="{x:Bind _stylesViewModel.SelectedPieceTheme, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Live Board Preview -->
                    <Border
                        Grid.Column="1"
                        Width="240"
                        Height="240"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid>
                            <!-- Board background (updates live) -->
                            <Grid.Background>
                                <ImageBrush
                                    x:Name="PreviewBoardBrush"
                                    ImageSource="{x:Bind _previewBoardImage, Mode=OneWay}"
                                    Stretch="UniformToFill" />
                            </Grid.Background>

                            <!-- 4x4 mini-grid with sample pieces (updates live) -->
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Row 0: Black major pieces -->
                                <Image x:Name="PreviewBRook"   Grid.Row="0" Grid.Column="0" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBKnight" Grid.Row="0" Grid.Column="1" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBBishop" Grid.Row="0" Grid.Column="2" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBQueen"  Grid.Row="0" Grid.Column="3" Stretch="Uniform" Margin="2" />

                                <!-- Row 1: Black pawns -->
                                <Image x:Name="PreviewBPawn0" Grid.Row="1" Grid.Column="0" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBPawn1" Grid.Row="1" Grid.Column="1" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBPawn2" Grid.Row="1" Grid.Column="2" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewBPawn3" Grid.Row="1" Grid.Column="3" Stretch="Uniform" Margin="2" />

                                <!-- Row 2: White pawns -->
                                <Image x:Name="PreviewWPawn0" Grid.Row="2" Grid.Column="0" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWPawn1" Grid.Row="2" Grid.Column="1" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWPawn2" Grid.Row="2" Grid.Column="2" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWPawn3" Grid.Row="2" Grid.Column="3" Stretch="Uniform" Margin="2" />

                                <!-- Row 3: White major pieces -->
                                <Image x:Name="PreviewWRook"   Grid.Row="3" Grid.Column="0" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWKnight" Grid.Row="3" Grid.Column="1" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWBishop" Grid.Row="3" Grid.Column="2" Stretch="Uniform" Margin="2" />
                                <Image x:Name="PreviewWQueen"  Grid.Row="3" Grid.Column="3" Stretch="Uniform" Margin="2" />
                            </Grid>

                            <!-- "Live Preview" label -->
                            <Border
                                Margin="6"
                                Padding="6,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Live Preview" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>


            <!-- ==================== AUDIO ==================== -->
            <Border
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24">
                <StackPanel Spacing="20">

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Audio" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Control master volume, sound effects, and atmosphere" />
                    </StackPanel>

                    <!-- Master Volume -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Master" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Overall level" />
                        </StackPanel>

                        <Slider
                            x:Name="MasterVolumeSlider"
                            Grid.Column="1"
                            Maximum="100"
                            Minimum="0"
                            PointerCaptureLost="Master_Volume_PointerCaptureLost"
                            SnapsTo="StepValues"
                            StepFrequency="10"
                            Value="{x:Bind _audioViewModel.MasterVolume, Mode=OneWay}" />
                    </Grid>

                    <!-- Divider -->
                    <Border
                        Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- SFX -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Sound Effects" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Moves, captures" />
                        </StackPanel>

                        <Slider
                            x:Name="SfxVolumeSlider"
                            Grid.Column="1"
                            Maximum="100"
                            Minimum="0"
                            PointerCaptureLost="SFX_Volume_PointerCaptureLost"
                            SnapsTo="StepValues"
                            StepFrequency="10"
                            Value="{x:Bind _audioViewModel.SfxVolume, Mode=OneWay}" />

                        <ToggleSwitch
                            Grid.Column="2"
                            IsOn="{x:Bind _audioViewModel.SfxEnabled, Mode=TwoWay}"
                            OffContent=""
                            OnContent="" />
                    </Grid>

                    <!-- Divider -->
                    <Border
                        Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Atmosphere -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Atmosphere" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Background ambience" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <Slider
                                x:Name="AtmosVolumeSlider"
                                Maximum="100"
                                Minimum="0"
                                PointerCaptureLost="Atmos_Volume_PointerCaptureLost"
                                SnapsTo="StepValues"
                                StepFrequency="10"
                                Value="{x:Bind _audioViewModel.AtmosVolume, Mode=OneWay}" />

                            <ComboBox
                                HorizontalAlignment="Stretch"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind _audioViewModel.AtmosphereSoundscapes}"
                                SelectedItem="{x:Bind _audioViewModel.SelectedAtmosphereSoundscape, Mode=TwoWay}" />
                        </StackPanel>

                        <ToggleSwitch
                            Grid.Column="2"
                            IsOn="{x:Bind _audioViewModel.AtmosEnabled, Mode=TwoWay}"
                            OffContent=""
                            OnContent="" />
                    </Grid>
                </StackPanel>
            </Border>


            <!-- ==================== MULTIPLAYER ==================== -->
            <Border
                Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24">
                <StackPanel Spacing="20">

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="20"
                            FontWeight="SemiBold"
                            Text="Multiplayer" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Network and player identity settings" />
                    </StackPanel>

                    <!-- Player Name -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Player Name" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Visible to others" />
                        </StackPanel>

                        <TextBox
                            Grid.Column="1"
                            PlaceholderText="Enter your name"
                            Text="{x:Bind _multiplayerPrefsViewModel.LocalPlayerName, Mode=TwoWay}" />
                    </Grid>

                    <!-- Divider -->
                    <Border
                        Height="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <!-- Network Adapter -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Network" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="Local adapter" />
                        </StackPanel>

                        <ComboBox
                            x:Name="NetworkAdapterComboBox"
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            ItemContainerStyleSelector="{StaticResource ComboBoxItemContainerStyleSelector}"
                            ItemTemplateSelector="{StaticResource NetworkAdapterSelector}"
                            ItemsSource="{x:Bind _multiplayerPrefsViewModel.NetworkAdapterNodes}"
                            SelectedItem="{x:Bind _multiplayerPrefsViewModel.SelectedNetworkAdaperNode, Mode=TwoWay}"
                            SelectionChanged="NetworkAdapterChanged" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
